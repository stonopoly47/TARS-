# LiveKit server / project credentials (from cloud.livekit.io or your self-hosted server)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Claude via OpenRouter (LLM) - https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Deepgram (STT - Nova-3)
DEEPGRAM_API_KEY=your_deepgram_api_key

# ElevenLabs (TTS)
ELEVENLABS_API_KEY=your_elevenlabs_api_key
# Optional: pick a specific voice, otherwise the plugin default is used
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
